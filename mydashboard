<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Your Dashboard 👀</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:#0a0118;min-height:100vh;font-family:'DM Sans',sans-serif;color:#f0e6ff;padding:1.5rem 1rem 4rem}
.header{text-align:center;padding:1.5rem 0 1rem}
.header h1{font-family:'Caveat',cursive;font-size:2.2rem;background:linear-gradient(135deg,#f9c8ff,#f5c842);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.header p{color:#8b6fa8;font-size:.85rem;margin-top:.3rem}
.refresh-btn{display:block;margin:.8rem auto 0;background:rgba(124,58,237,.3);border:1.5px solid rgba(124,58,237,.5);color:#c4a0e8;border-radius:2rem;padding:.4rem 1.4rem;font-size:.85rem;cursor:pointer;transition:all .2s}
.refresh-btn:hover{background:rgba(124,58,237,.5);color:#fff}

.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;max-width:600px;margin:1.2rem auto}
.stat-box{background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.08);border-radius:1rem;padding:.9rem;text-align:center}
.stat-num{font-family:'Caveat',cursive;font-size:2rem;font-weight:700;color:#f9c8ff}
.stat-label{font-size:.72rem;color:#8b6fa8;text-transform:uppercase;letter-spacing:.06em;margin-top:.2rem}

.section{max-width:600px;margin:1.4rem auto}
.sec-head{font-family:'Caveat',cursive;font-size:1.3rem;color:#f9c8ff;margin-bottom:.7rem;padding-bottom:.4rem;border-bottom:1px solid rgba(255,255,255,.08)}

.log-item{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:.9rem;padding:.8rem 1rem;margin-bottom:.6rem;display:flex;gap:.8rem;align-items:flex-start}
.log-icon{font-size:1.2rem;flex-shrink:0;margin-top:.1rem}
.log-body{flex:1}
.log-title{font-size:.88rem;color:#e2b8ff;font-weight:500;line-height:1.4}
.log-detail{font-size:.78rem;color:#7a5fa0;margin-top:.2rem;font-style:italic}
.log-time{font-size:.68rem;color:#5a4070;margin-top:.3rem}
.tag{display:inline-block;font-size:.65rem;padding:.15rem .5rem;border-radius:1rem;font-weight:600;margin-right:.3rem}
.tag-truth{background:#dbeafe;color:#1d4ed8}
.tag-dare{background:#fce7f3;color:#9d174d}
.tag-action{background:#d1fae5;color:#065f46}
.tag-match{background:rgba(124,200,66,.2);color:#7ecba1}
.tag-nomatch{background:rgba(232,121,160,.15);color:#e879a0}
.tag-unlocked{background:rgba(245,200,66,.2);color:#f5c842}
.tag-wrong{background:rgba(224,90,122,.2);color:#e05a7a}

/* vault passwords cheatsheet */
.cheatsheet{background:rgba(245,200,66,.07);border:1.5px solid rgba(245,200,66,.2);border-radius:1rem;padding:1rem 1.2rem;margin-bottom:1.2rem}
.cheatsheet h3{font-family:'Caveat',cursive;font-size:1.1rem;color:#f5c842;margin-bottom:.6rem}
.pw-row{display:flex;justify-content:space-between;align-items:center;padding:.35rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.85rem}
.pw-row:last-child{border-bottom:none}
.pw-label{color:#c4a0e8}.pw-value{color:#f5c842;font-family:'Caveat',cursive;font-size:1rem;letter-spacing:.05em}

.empty-state{text-align:center;padding:2.5rem 1rem;color:#5a4070}
.empty-state .e-icon{font-size:2.5rem;margin-bottom:.6rem}
.empty-state p{font-family:'Caveat',cursive;font-size:1.1rem}

.wyr-summary{display:grid;gap:.6rem}
.wyr-row{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:.9rem;padding:.8rem 1rem}
.wyr-q{font-size:.8rem;color:#8b6fa8;margin-bottom:.3rem}
.wyr-picks{display:flex;gap:.5rem;align-items:center;font-size:.88rem}
.her-pick{color:#e879a0;font-weight:500}
.my-pick-label{color:#f5c842;font-weight:500}
</style>
</head>
<body>

<div class="header">
  <h1>👀 Your Dashboard</h1>
  <p>everything May~Cee has done — live from her browser</p>
  <button class="refresh-btn" onclick="loadDashboard()">↻ refresh</button>
</div>

<!-- Stats -->
<div class="stats-row">
  <div class="stat-box"><div class="stat-num" id="statTotal">0</div><div class="stat-label">total actions</div></div>
  <div class="stat-box"><div class="stat-num" id="statCards">0</div><div class="stat-label">cards flipped</div></div>
  <div class="stat-box"><div class="stat-num" id="statSpins">0</div><div class="stat-label">wheel spins</div></div>
</div>

<!-- Password Cheatsheet -->
<div class="section">
  <div class="cheatsheet">
    <h3>🔑 Vault Passwords — drip these slowly 😏</h3>
    <div class="pw-row"><span class="pw-label">💛 Golden Memory</span><span class="pw-value">sana</span></div>
    <div class="pw-row"><span class="pw-label">🥺 The Real One</span><span class="pw-value">maycee</span></div>
    <div class="pw-row"><span class="pw-label">✨ Future Us</span><span class="pw-value">next time</span></div>
    <div class="pw-row"><span class="pw-label">🔥 The Secret</span><span class="pw-value">star</span></div>
  </div>
</div>

<!-- Cards flipped -->
<div class="section">
  <div class="sec-head">🎴 Cards She Flipped</div>
  <div id="cardsLog"><div class="empty-state"><div class="e-icon">🎴</div><p>no cards flipped yet</p></div></div>
</div>

<!-- Vault activity -->
<div class="section">
  <div class="sec-head">🔐 Vault Activity</div>
  <div id="vaultLog"><div class="empty-state"><div class="e-icon">🔒</div><p>no vault attempts yet</p></div></div>
</div>

<!-- Letters opened -->
<div class="section">
  <div class="sec-head">💌 Letters She Opened</div>
  <div id="lettersLog"><div class="empty-state"><div class="e-icon">💌</div><p>no letters opened yet</p></div></div>
</div>

<!-- Wheel spins -->
<div class="section">
  <div class="sec-head">🎰 Wheel Results</div>
  <div id="wheelLog"><div class="empty-state"><div class="e-icon">🎰</div><p>no spins yet</p></div></div>
</div>

<!-- Would you rather -->
<div class="section">
  <div class="sec-head">💭 Would You Rather Picks</div>
  <div id="wyrLog"><div class="empty-state"><div class="e-icon">💭</div><p>no picks yet</p></div></div>
</div>

<!-- Puzzle progress -->
<div class="section">
  <div class="sec-head">🧩 Puzzle Progress</div>
  <div id="puzzleLog"><div class="empty-state"><div class="e-icon">🧩</div><p>puzzle not started yet</p></div></div>
</div>

<!-- Full raw log -->
<div class="section">
  <div class="sec-head">📋 Full Activity Timeline</div>
  <div id="fullLog"><div class="empty-state"><div class="e-icon">📋</div><p>nothing yet — send her the page!</p></div></div>
</div>

<script>
function timeAgo(iso){
  const diff=(Date.now()-new Date(iso))/1000;
  if(diff<60) return Math.floor(diff)+'s ago';
  if(diff<3600) return Math.floor(diff/60)+'m ago';
  if(diff<86400) return Math.floor(diff/3600)+'h ago';
  return new Date(iso).toLocaleDateString();
}

function loadDashboard(){
  const raw=localStorage.getItem('maycee_log');
  const logs=raw?JSON.parse(raw):[];

  // stats
  document.getElementById('statTotal').textContent=logs.length;
  document.getElementById('statCards').textContent=logs.filter(l=>l.type==='card_flip').length;
  document.getElementById('statSpins').textContent=logs.filter(l=>l.type==='wheel_spin').length;

  // cards
  const cardLogs=logs.filter(l=>l.type==='card_flip');
  const cardsEl=document.getElementById('cardsLog');
  if(cardLogs.length===0){cardsEl.innerHTML='<div class="empty-state"><div class="e-icon">🎴</div><p>no cards flipped yet</p></div>'}
  else{cardsEl.innerHTML=cardLogs.map(l=>`
    <div class="log-item">
      <div class="log-icon">${l.data.type==='truth'?'🤔':l.data.type==='dare'?'🔥':'⚡'}</div>
      <div class="log-body">
        <div class="log-title"><span class="tag tag-${l.data.type}">${l.data.type}</span>${l.data.text}</div>
        <div class="log-time">${timeAgo(l.time)}</div>
      </div>
    </div>`).join('')}

  // vault
  const vaultLogs=logs.filter(l=>l.type==='vault_attempt'||l.type==='vault_unlocked');
  const vaultEl=document.getElementById('vaultLog');
  if(vaultLogs.length===0){vaultEl.innerHTML='<div class="empty-state"><div class="e-icon">🔒</div><p>no vault attempts yet</p></div>'}
  else{vaultEl.innerHTML=vaultLogs.map(l=>{
    if(l.type==='vault_unlocked') return `<div class="log-item"><div class="log-icon">🔓</div><div class="log-body"><div class="log-title"><span class="tag tag-unlocked">UNLOCKED</span>${l.data.vault}</div><div class="log-time">${timeAgo(l.time)}</div></div></div>`;
    return `<div class="log-item"><div class="log-icon">${l.data.correct?'✅':'❌'}</div><div class="log-body"><div class="log-title"><span class="tag ${l.data.correct?'tag-unlocked':'tag-wrong'}">${l.data.correct?'correct':'wrong'}</span>${l.data.vault}</div><div class="log-detail">she tried: "${l.data.attempt}"</div><div class="log-time">${timeAgo(l.time)}</div></div></div>`;
  }).join('')}

  // letters
  const letterLogs=logs.filter(l=>l.type==='letter_opened');
  const lettersEl=document.getElementById('lettersLog');
  if(letterLogs.length===0){lettersEl.innerHTML='<div class="empty-state"><div class="e-icon">💌</div><p>no letters opened yet</p></div>'}
  else{lettersEl.innerHTML=letterLogs.map(l=>`<div class="log-item"><div class="log-icon">💌</div><div class="log-body"><div class="log-title">${l.data.title}</div><div class="log-time">${timeAgo(l.time)}</div></div></div>`).join('')}

  // wheel
  const wheelLogs=logs.filter(l=>l.type==='wheel_spin');
  const wheelEl=document.getElementById('wheelLog');
  if(wheelLogs.length===0){wheelEl.innerHTML='<div class="empty-state"><div class="e-icon">🎰</div><p>no spins yet</p></div>'}
  else{wheelEl.innerHTML=wheelLogs.map(l=>`<div class="log-item"><div class="log-icon">🎰</div><div class="log-body"><div class="log-title">${l.data.result}</div><div class="log-detail">${l.data.full}</div><div class="log-time">${timeAgo(l.time)}</div></div></div>`).join('')}

  // wyr
  const wyrLogs=logs.filter(l=>l.type==='wyr_pick');
  const wyrEl=document.getElementById('wyrLog');
  if(wyrLogs.length===0){wyrEl.innerHTML='<div class="empty-state"><div class="e-icon">💭</div><p>no picks yet</p></div>'}
  else{wyrEl.innerHTML='<div class="wyr-summary">'+wyrLogs.map(l=>`
    <div class="wyr-row">
      <div class="wyr-q">${l.data.question}</div>
      <div class="wyr-picks">
        <span class="her-pick">she picked: ${l.data.picked}</span>
        <span style="color:#5a4070;font-size:.8rem">vs</span>
        <span class="my-pick-label">you: ${l.data.myPick}</span>
        <span class="tag ${l.data.matched?'tag-match':'tag-nomatch'}">${l.data.matched?'✅ match':'❌ diff'}</span>
      </div>
      <div class="log-time">${timeAgo(l.time)}</div>
    </div>`).join('')+'</div>'}

  // puzzle
  const puzzleLogs=logs.filter(l=>l.type==='puzzle_piece'||l.type==='puzzle_start'||l.type==='puzzle_complete');
  const puzzleEl=document.getElementById('puzzleLog');
  if(puzzleLogs.length===0){puzzleEl.innerHTML='<div class="empty-state"><div class="e-icon">🧩</div><p>puzzle not started yet</p></div>'}
  else{
    const pieces=puzzleLogs.filter(l=>l.type==='puzzle_piece').length+1;
    const done=puzzleLogs.find(l=>l.type==='puzzle_complete');
    puzzleEl.innerHTML=`<div class="log-item"><div class="log-icon">🧩</div><div class="log-body"><div class="log-title">${done?'🎉 puzzle complete!':pieces+' / 9 pieces revealed'}</div><div class="log-detail">${done?'she completed everything 🎉':'still going…'}</div><div class="log-time">${timeAgo(puzzleLogs[puzzleLogs.length-1].time)}</div></div></div>`;
  }

  // full timeline
  const fullEl=document.getElementById('fullLog');
  if(logs.length===0){fullEl.innerHTML='<div class="empty-state"><div class="e-icon">📋</div><p>nothing yet — send her the page!</p></div>'}
  else{
    const icons={card_flip:'🎴',vault_attempt:'🔐',vault_unlocked:'🔓',letter_opened:'💌',wheel_spin:'🎰',puzzle_start:'🧩',puzzle_piece:'🧩',puzzle_complete:'🎉',wyr_pick:'💭',tab_visit:'👆'};
    fullEl.innerHTML=[...logs].reverse().map(l=>`
      <div class="log-item">
        <div class="log-icon">${icons[l.type]||'📌'}</div>
        <div class="log-body">
          <div class="log-title">${l.type.replace(/_/g,' ')}</div>
          <div class="log-detail">${JSON.stringify(l.data).replace(/[{}"]/g,'').replace(/,/g,' · ').substring(0,120)}</div>
          <div class="log-time">${timeAgo(l.time)}</div>
        </div>
      </div>`).join('')}
}

loadDashboard();
// auto refresh every 15 seconds
setInterval(loadDashboard, 15000);
</script>
</body>
</html>
